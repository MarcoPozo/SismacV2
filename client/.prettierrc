{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "tabWidth": 2,
  "printWidth": 100,
  "plugins": [
    "@trivago/prettier-plugin-sort-imports"
  ],
  "importOrder": [
    "^react$",
    "^react-(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^\\.\\./(styles|styles/.*)$",
    "^\\./(.*)\\.css$",
    "^\\.\\./.*\\.css$",
    "^\\.\\./(shell|panels|ui|apps)/(.*)",
    "^\\.\\./(store)/(.*)",
    "^\\.\\./(hooks)/(.*)",
    "^\\.\\./(config)/(.*)",
    "^\\./(.*)"
  ],
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true
}